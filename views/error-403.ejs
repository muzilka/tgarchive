<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Доступ запрещен</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            background: linear-gradient(135deg, #0e1621 0%, #1a2a3a 100%);
            color: #ffffff;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 20px;
        }
        
        .error-container {
            text-align: center;
            max-width: 500px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 60px 40px;
            backdrop-filter: blur(10px);
        }
        
        .error-code {
            font-size: 120px;
            font-weight: 700;
            color: #ff6b6b;
            margin-bottom: 20px;
            text-shadow: 0 4px 20px rgba(255, 107, 107, 0.3);
        }
        
        .error-title {
            font-size: 28px;
            font-weight: 600;
            margin-bottom: 15px;
            color: #ffffff;
        }
        
        .error-message {
            font-size: 16px;
            color: #b0b8c1;
            margin-bottom: 30px;
            line-height: 1.6;
        }
        
        .required-group {
            background: rgba(255, 107, 107, 0.1);
            border: 1px solid rgba(255, 107, 107, 0.3);
            border-radius: 8px;
            padding: 15px;
            margin: 20px 0;
            text-align: left;
        }
        
        .required-group-label {
            font-size: 12px;
            color: #ff6b6b;
            text-transform: uppercase;
            font-weight: 600;
            margin-bottom: 8px;
        }
        
        .required-group-name {
            font-family: 'Monaco', 'Courier New', monospace;
            font-size: 14px;
            color: #4db8ff;
            word-break: break-all;
        }
        
        .your-groups {
            background: rgba(45, 85, 120, 0.2);
            border: 1px solid rgba(45, 85, 120, 0.4);
            border-radius: 8px;
            padding: 15px;
            margin: 20px 0;
            text-align: left;
        }
        
        .your-groups-label {
            font-size: 12px;
            color: #4db8ff;
            text-transform: uppercase;
            font-weight: 600;
            margin-bottom: 10px;
        }
        
        .groups-list {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }
        
        .group-tag {
            background: rgba(45, 85, 120, 0.4);
            border: 1px solid rgba(45, 85, 120, 0.6);
            border-radius: 20px;
            padding: 6px 12px;
            font-size: 12px;
            color: #a8c5dd;
        }
        
        .actions {
            display: flex;
            gap: 12px;
            margin-top: 40px;
        }
        
        .btn {
            flex: 1;
            padding: 12px 24px;
            border: none;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
        
        .btn-primary {
            background: #2b5278;
            color: white;
        }
        
        .btn-primary:hover {
            background: #3a6fa0;
            transform: translateY(-2px);
        }
        
        .btn-secondary {
            background: transparent;
            color: #4db8ff;
            border: 1px solid #4db8ff;
        }
        
        .btn-secondary:hover {
            background: rgba(77, 184, 255, 0.1);
        }
    </style>
</head>
<body>
    <div class="error-container">
        <div class="error-code">403</div>
        <div class="error-title">Доступ ограничен</div>
        <div class="error-message">
            У вас нет необходимых прав для просмотра этого чата.
        </div>
        
        <% if (requiredGroup) { %>
            <div class="required-group">
                <div class="required-group-label">Требуемая группа</div>
                <div class="required-group-name"><%= requiredGroup %></div>
            </div>
        <% } %>
        
        <% if (userGroups && userGroups.length > 0) { %>
            <div class="your-groups">
                <div class="your-groups-label">Ваши группы</div>
                <div class="groups-list">
                    <% userGroups.forEach(group => { %>
                        <span class="group-tag"><%= group %></span>
                    <% }) %>
                </div>
            </div>
        <% } else { %>
            <div class="your-groups">
                <div class="your-groups-label">Ваши группы</div>
                <div style="color: #708499; font-size: 14px;">Вы не состоите ни в одной группе</div>
            </div>
        <% } %>
        
        <div class="actions">
            <a href="/" class="btn btn-primary">К списку чатов</a>
            <a href="/auth/logout" class="btn btn-secondary">Выход</a>
        </div>
    </div>
</body>
</html>
